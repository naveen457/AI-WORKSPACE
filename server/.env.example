PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://your_db_user:your_db_password@your_cluster.mongodb.net/astrix   //Or you can use your own MongoDB connection string without srv
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# JWT & Session Secrets
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# Resend settings for OTP emails
RESEND_API_KEY=your_resend_api_key
RESEND_FROM="Astrix <noreply@astrix-app.me>"
RESEND_REPLY_TO=support@astrix-app.me

# Phone OTP settings
PHONE_OTP_PROVIDER=twilio
PHONE_OTP_DEFAULT_COUNTRY_CODE=+1
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12345678900

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://localhost:5000/auth/google/callback

# GitHub OAuth Configuration
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://localhost:5000/auth/github/callback
